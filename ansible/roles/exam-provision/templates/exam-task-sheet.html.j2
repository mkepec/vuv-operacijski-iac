<script>
function toggleLang(btn) {
  var body = document.body;
  if (body.classList.contains('lang-en')) {
    body.classList.replace('lang-en', 'lang-hr');
    btn.textContent = 'Show English';
  } else {
    body.classList.replace('lang-hr', 'lang-en');
    btn.textContent = 'Prikaži hrvatski';
  }
}
</script>
