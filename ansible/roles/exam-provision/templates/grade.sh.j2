#!/bin/bash
# Student grading script — RH124 mid-semester exam
# Variant: {{ exam_variant }}  Host: {{ inventory_hostname }}
# Generated by Ansible at provisioning time. Do not edit.

VARIANT="{{ exam_variant }}"
HOSTNAME="{{ inventory_hostname }}"
EXAM_DIR="{{ exam_dir }}"
EXAM_USERNAME="{{ exam_username }}"
EXAM_GID="{{ exam_gid }}"
EXAM_EXPIRY="{{ exam_expiry }}"
EXAM_WORKSPACE="{{ exam_workspace }}"
EXAM_MOUNT="{{ exam_mount }}"
EXAM_MOUNT_TEXT="{{ exam_mount_text }}"
EXAM_EXTRA_PACKAGE="{{ exam_extra_package }}"

PASS=0
FAIL=1

pass() { echo "  [PASS] $1"; }
fail() { echo "  [FAIL] $1"; }

run_task() {
    local task="$1"
    case "$task" in
        t1) grade_t1 ;;
        t2) grade_t2 ;;
        t3) grade_t3 ;;
        t4) grade_t4 ;;
        t5) grade_t5 ;;
        t6) grade_t6 ;;
        *) echo "Unknown task: $task"; exit 1 ;;
    esac
}

grade_t1() {
    local score=0 max=15
    echo ""
    echo "Task 1 — File and Directory Management"

    if [ -d "/home/student/projects/${EXAM_DIR}" ]; then
        pass "Directory /home/student/projects/${EXAM_DIR} exists"; ((score+=2))
    else
        fail "Directory /home/student/projects/${EXAM_DIR} missing"
    fi

    local files_ok=true
    for f in report.txt backup.txt notes.txt; do
        [ -f "/home/student/projects/${EXAM_DIR}/$f" ] || files_ok=false
    done
    if $files_ok; then
        pass "Files report.txt, backup.txt, notes.txt exist"; ((score+=2))
    else
        fail "One or more of report.txt, backup.txt, notes.txt missing"
    fi

    if diff -q /etc/hostname "/home/student/projects/${EXAM_DIR}/hostname.txt" &>/dev/null; then
        pass "hostname.txt matches /etc/hostname"; ((score+=2))
    else
        fail "hostname.txt does not match /etc/hostname"
    fi

    local expected
    expected=$(tail -5 /etc/passwd)
    local report_content
    report_content=$(cat "/home/student/projects/${EXAM_DIR}/report.txt" 2>/dev/null)
    if echo "$report_content" | grep -qF "$(tail -1 /etc/passwd)"; then
        pass "report.txt contains last 5 lines of /etc/passwd"; ((score+=3))
    else
        fail "report.txt does not contain last 5 lines of /etc/passwd"
    fi

    local link_count
    link_count=$(stat -c %h "/home/student/projects/${EXAM_DIR}/report.txt" 2>/dev/null)
    if [ "/home/student/projects/report-link-${VARIANT}" -ef "/home/student/projects/${EXAM_DIR}/report.txt" ] 2>/dev/null && [ "${link_count:-0}" -ge 2 ]; then
        pass "Hard link report-link-${VARIANT} verified (link count = ${link_count})"; ((score+=3))
    else
        fail "Hard link /home/student/projects/report-link-${VARIANT} missing or incorrect"
    fi

    if [ -L "/home/student/exam-shortcut" ] && [ "$(readlink -f /home/student/exam-shortcut)" = "/home/student/projects/${EXAM_DIR}" ]; then
        pass "Symbolic link exam-shortcut verified"; ((score+=3))
    else
        fail "Symbolic link /home/student/exam-shortcut missing or points to wrong target"
    fi

    echo "  Score: ${score}/${max}"
    echo "$score $max"
}

grade_t2() {
    local score=0 max=20
    echo ""
    echo "Task 2 — Users, Groups, and Password Policy"

    if getent group dbteam | grep -q ":${EXAM_GID}:"; then
        pass "Group dbteam exists with GID ${EXAM_GID}"; ((score+=3))
    else
        fail "Group dbteam missing or has wrong GID (expected ${EXAM_GID})"
    fi

    if id "${EXAM_USERNAME}" &>/dev/null && id "${EXAM_USERNAME}" | grep -q "dbteam"; then
        pass "User ${EXAM_USERNAME} exists and is in dbteam"; ((score+=2))
    else
        fail "User ${EXAM_USERNAME} missing or not in dbteam"
    fi

    if passwd -S "${EXAM_USERNAME}" 2>/dev/null | grep -qv ' LK '; then
        pass "Password is set (account not locked)"; ((score+=2))
    else
        fail "Password not set or account locked for ${EXAM_USERNAME}"
    fi

    if chage -l "${EXAM_USERNAME}" 2>/dev/null | grep -qi 'last password change.*password must be changed'; then
        pass "Force password change on first login is set"; ((score+=3))
    else
        fail "Force password change on first login is not configured"
    fi

    if chage -l "${EXAM_USERNAME}" 2>/dev/null | grep -q 'Minimum.*7'; then
        pass "Minimum days between password changes: 7"; ((score+=2))
    else
        fail "Minimum days between password changes is not 7"
    fi

    if chage -l "${EXAM_USERNAME}" 2>/dev/null | grep -q 'Maximum.*60'; then
        pass "Maximum days before password change required: 60"; ((score+=2))
    else
        fail "Maximum days before password change required is not 60"
    fi

    if chage -l "${EXAM_USERNAME}" 2>/dev/null | grep -qi "account expires.*${EXAM_EXPIRY}"; then
        pass "Account expiry date: ${EXAM_EXPIRY}"; ((score+=2))
    else
        fail "Account expiry date is not ${EXAM_EXPIRY}"
    fi

    if sudo -l -U "${EXAM_USERNAME}" 2>/dev/null | grep -q 'NOPASSWD'; then
        pass "NOPASSWD sudo configured for ${EXAM_USERNAME}"; ((score+=4))
    else
        fail "NOPASSWD sudo not configured for ${EXAM_USERNAME}"
    fi

    echo "  Score: ${score}/${max}"
    echo "$score $max"
}

grade_t3() {
    local score=0 max=20
    echo ""
    echo "Task 3 — File Permissions and Collaborative Directory"

    if [ -d "/home/${EXAM_WORKSPACE}" ]; then
        pass "Directory /home/${EXAM_WORKSPACE} exists"; ((score+=2))
    else
        fail "Directory /home/${EXAM_WORKSPACE} missing"
    fi

    local grp
    grp=$(stat -c %G "/home/${EXAM_WORKSPACE}" 2>/dev/null)
    if [ "$grp" = "dbteam" ]; then
        pass "Group owner is dbteam"; ((score+=3))
    else
        fail "Group owner is '${grp}', expected dbteam"
    fi

    local perms
    perms=$(stat -c %A "/home/${EXAM_WORKSPACE}" 2>/dev/null)
    if echo "$perms" | grep -q '^drwx'; then
        pass "Owner has rwx"; ((score+=1))
    else
        fail "Owner does not have full rwx (permissions: ${perms})"
    fi

    if echo "$perms" | cut -c5-7 | grep -q 'rwx'; then
        pass "Group has rwx"; ((score+=2))
    else
        fail "Group does not have rwx (permissions: ${perms})"
    fi

    if echo "$perms" | cut -c8-10 | grep -q '^---\|^--T\|^--t'; then
        pass "Others have no access"; ((score+=2))
    else
        fail "Others have some access (permissions: ${perms})"
    fi

    if echo "$perms" | cut -c6 | grep -q '[sS]'; then
        pass "SGID bit is set"; ((score+=4))
    else
        fail "SGID bit is not set (permissions: ${perms})"
    fi

    if echo "$perms" | cut -c10 | grep -q '[Tt]'; then
        pass "Sticky bit is set"; ((score+=4))
    else
        fail "Sticky bit is not set (permissions: ${perms})"
    fi

    if grep -q 'umask 007' "/home/${EXAM_USERNAME}/.bashrc" 2>/dev/null || grep -q 'umask 007' "/home/${EXAM_USERNAME}/.bash_profile" 2>/dev/null; then
        pass "umask 007 found in ${EXAM_USERNAME}'s shell config"; ((score+=2))
    else
        fail "umask 007 not found in ${EXAM_USERNAME}/.bashrc or .bash_profile"
    fi

    echo "  Score: ${score}/${max}"
    echo "$score $max"
}

grade_t4() {
    local score=0 max=15
    echo ""
    echo "Task 4 — Service Management"

    local crond_active
    crond_active=$(systemctl is-active crond 2>/dev/null)
    if [ "$crond_active" = "active" ]; then
        pass "crond is active"; ((score+=2))
    else
        fail "crond is not active (state: ${crond_active})"
    fi

    local crond_enabled
    crond_enabled=$(systemctl is-enabled crond 2>/dev/null)
    if [ "$crond_enabled" = "enabled" ]; then
        pass "crond is enabled"; ((score+=3))
    else
        fail "crond is not enabled (state: ${crond_enabled})"
    fi

    local rsyslog_active
    rsyslog_active=$(systemctl is-active rsyslog 2>/dev/null)
    if [ "$rsyslog_active" = "inactive" ]; then
        pass "rsyslog is inactive"; ((score+=2))
    else
        fail "rsyslog is not inactive (state: ${rsyslog_active})"
    fi

    local rsyslog_enabled
    rsyslog_enabled=$(systemctl is-enabled rsyslog 2>/dev/null)
    if [ "$rsyslog_enabled" = "disabled" ]; then
        pass "rsyslog is disabled"; ((score+=3))
    else
        fail "rsyslog is not disabled (state: ${rsyslog_enabled})"
    fi

    # Check if system has been rebooted since provisioning
    if [ -f /var/exam-provision-time ]; then
        local provision_ts
        provision_ts=$(stat -c %Y /var/exam-provision-time)
        local boot_ts
        boot_ts=$(date -d "$(who -b | awk '{print $3, $4}')" +%s 2>/dev/null)
        if [ -n "$boot_ts" ] && [ "$boot_ts" -gt "$provision_ts" ]; then
            pass "System has been rebooted since provisioning"; ((score+=5))
        else
            fail "System has NOT been rebooted since provisioning — run: sudo systemctl reboot"
        fi
    else
        fail "Provisioning timestamp file missing — cannot verify reboot"
    fi

    echo "  Score: ${score}/${max}"
    echo "$score $max"
}

grade_t5() {
    local score=0 max=15
    echo ""
    echo "Task 5 — Package Management and Custom Repository"

    if [ -f /etc/yum.repos.d/exam.repo ]; then
        pass "exam.repo file exists"; ((score+=1))
    else
        fail "/etc/yum.repos.d/exam.repo does not exist"
    fi

    if grep -q 'baseurl.*172\.16\.16\.121/repo' /etc/yum.repos.d/exam.repo 2>/dev/null; then
        pass "baseurl points to 172.16.16.121/repo"; ((score+=2))
    else
        fail "baseurl does not point to 172.16.16.121/repo"
    fi

    if grep -q 'enabled=1' /etc/yum.repos.d/exam.repo 2>/dev/null; then
        pass "enabled=1 is set"; ((score+=1))
    else
        fail "enabled=1 not found in exam.repo"
    fi

    if grep -q 'gpgcheck=0' /etc/yum.repos.d/exam.repo 2>/dev/null; then
        pass "gpgcheck=0 is set"; ((score+=2))
    else
        fail "gpgcheck=0 not found in exam.repo"
    fi

    if rpm -q vim-enhanced &>/dev/null; then
        pass "vim-enhanced is installed"; ((score+=3))
    else
        fail "vim-enhanced is not installed"
    fi

    if rpm -q "${EXAM_EXTRA_PACKAGE}" &>/dev/null; then
        pass "${EXAM_EXTRA_PACKAGE} is installed"; ((score+=3))
    else
        fail "${EXAM_EXTRA_PACKAGE} is not installed"
    fi

    if ! rpm -q tmux &>/dev/null; then
        pass "tmux is not installed"; ((score+=3))
    else
        fail "tmux is still installed — remove it with: sudo dnf remove tmux"
    fi

    echo "  Score: ${score}/${max}"
    echo "$score $max"
}

grade_t6() {
    local score=0 max=15
    echo ""
    echo "Task 6 — Mount a File System and Search for Files"

    if [ -d "${EXAM_MOUNT}" ]; then
        pass "Mount point ${EXAM_MOUNT} exists"; ((score+=1))
    else
        fail "Mount point ${EXAM_MOUNT} does not exist"
    fi

    if findmnt "${EXAM_MOUNT}" &>/dev/null; then
        pass "Partition is currently mounted at ${EXAM_MOUNT}"; ((score+=1))
    else
        fail "Nothing is mounted at ${EXAM_MOUNT}"
    fi

    if grep -q "${EXAM_MOUNT}" /etc/fstab 2>/dev/null; then
        pass "/etc/fstab entry exists for ${EXAM_MOUNT}"; ((score+=3))
    else
        fail "No /etc/fstab entry for ${EXAM_MOUNT}"
    fi

    # Reboot check reuses T4 result — if system rebooted and mount is present, award points
    if [ -f /var/exam-provision-time ] && findmnt "${EXAM_MOUNT}" &>/dev/null; then
        local provision_ts
        provision_ts=$(stat -c %Y /var/exam-provision-time)
        local boot_ts
        boot_ts=$(date -d "$(who -b | awk '{print $3, $4}')" +%s 2>/dev/null)
        if [ -n "$boot_ts" ] && [ "$boot_ts" -gt "$provision_ts" ]; then
            pass "Mount survives reboot (verified)"; ((score+=2))
        else
            fail "Cannot verify reboot — run: sudo systemctl reboot, then check mount again"
        fi
    else
        fail "Mount not present or no provisioning timestamp — cannot verify reboot persistence"
    fi

    if grep -Fx "${EXAM_MOUNT_TEXT}" "${EXAM_MOUNT}/mounted.txt" &>/dev/null; then
        pass "mounted.txt contains correct text"; ((score+=2))
    else
        fail "mounted.txt missing or does not contain '${EXAM_MOUNT_TEXT}'"
    fi

    if [ -s "${EXAM_MOUNT}/large-files.txt" ] && grep -q '/etc/exam-data/bigfile.dat' "${EXAM_MOUNT}/large-files.txt" 2>/dev/null; then
        pass "large-files.txt is non-empty and contains known large file"; ((score+=3))
    else
        fail "large-files.txt missing, empty, or does not contain expected anchor file"
    fi

    local all_planted=true
    for f in /var/exam-data/record-01.dat /var/exam-data/record-02.dat /var/exam-data/record-03.dat; do
        grep -q "$f" "${EXAM_MOUNT}/perms-files.txt" 2>/dev/null || all_planted=false
    done
    if $all_planted; then
        pass "perms-files.txt contains all planted 640 files"; ((score+=3))
    else
        fail "perms-files.txt missing or does not list all planted files in /var/exam-data/"
    fi

    echo "  Score: ${score}/${max}"
    echo "$score $max"
}

# ---- main ----

TASKS=()
case "${1:-all}" in
    all) TASKS=(t1 t2 t3 t4 t5 t6) ;;
    t[1-6]) TASKS=("$1") ;;
    *) echo "Usage: grade [all|t1|t2|t3|t4|t5|t6]"; exit 1 ;;
esac

echo "===== EXAM GRADING REPORT ====="
echo "Hostname: ${HOSTNAME}  Variant: ${VARIANT}"

total=0
max_total=0
task_count=$(echo "${TASKS[*]}" | wc -w)

for t in "${TASKS[@]}"; do
    result=$(run_task "$t")
    echo "$result" | head -n -1
    read -r s m <<< "$(echo "$result" | tail -1)"
    (( total += s ))
    (( max_total += m ))
done

echo ""
if [ "$task_count" -gt 1 ]; then
    echo "TOTAL: ${total}/${max_total}"
fi
echo "================================"
